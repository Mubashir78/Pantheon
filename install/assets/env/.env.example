# Pantheon .env example
# Copy to .env and fill in. The install script creates this for you.
# Keys marked REQUIRED must be set for the system to function.
# Keys marked OPTIONAL can be left empty; the relevant service will
# report "not reachable" in the UI but the rest of Pantheon still works.

# ─── Composio bridge (REQUIRED for the wizard Step 4 "Connect Integrations") ──
# Sign up at https://composio.dev, create a project, copy the keys here.
# The bridge refuses to start without these (server.ts:15 process.exit(1)).
# See docs/COMPOSIO_SETUP.md for a step-by-step walkthrough.
COMPOSIO_CONSUMER_KEY=
COMPOSIO_AUTH_TOKEN=

# ─── n8n (OPTIONAL, currently broken — out of scope per user) ──────────────
# n8n is intentionally not started by the install script. The systemd
# service is currently crash-looping due to an npm install issue.
# See docs/N8N_SETUP.md if you want to fix it yourself.
N8N_HOST=http://localhost:5678
N8N_API_KEY=

# ─── LLM providers (REQUIRED for the default Hermes model routing) ─────────
# At least one provider key must be set. The model_router (in
# pantheon-core/mcp_server.py) picks the cheapest available provider
# per request.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ─── Athenaeum embeddings (REQUIRED for vector search) ────────────────────
# Used by mcp_server.py's _Embedder and mnemosyne (legacy). Ollama
# (local) is configured below; OpenRouter (cloud) is the fallback.
ATHENAEUM_EMBED_PROVIDER=ollama
ATHENAEUM_OLLAMA_MODEL=nomic-embed-text
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small

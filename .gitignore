# =============================================================================
# Pantheon .gitignore
# =============================================================================

# Personal knowledge store — never in git
athenaeum/
master-prompt.md

# Staging area — unprocessed content
Staging/

# Environment and secrets
.env
.env.local
.env.production
secrets/

# Local config overrides
config.local.yaml

# Runtime and cache
__pycache__/
*.pyc
.chroma/
.qdrant/
node_modules/

# Runtime logs
logs/

# Runtime messages — inter-god communication, never committed
gods/messages/

# Runtime state snapshots — never committed
planning/hermes-alive-state.json

# Instance-specific gods — only Hermes + Hephaestus ship in core
Codex-Apollo/
god-packages/god-apollo/
harnesses/apollo-base.yaml
harnesses/apollo-lyric-writing.yaml
harnesses/apollo-poetry.yaml
harnesses/caduceus-base.yaml
harnesses/god-apollo-base.yaml
harnesses/thoth-base.yaml

# One-time migration scripts — local to each instance
scripts/migrate-export.sh
scripts/migrate-oracle-vault.sh
scripts/migrate-restore.sh

# Replaced by pantheon-bundle — kept locally for reference
scripts/pantheon-export

# Personal content
canvas-and-the-world-fell-away.md
project-ideas.md
notes/
plans/
**/plans/
u55-fix.sh
webui/static/god_glow_screenshot.jpg

# Client prospect data — never committed
webui/static/prospect-pipeline.md

# Runtime state — never committed
data/
heartbeat_state.json
shared/

# Large binary assets (use SVG + HTML instead)
pantheon-logo.png
pantheon-architecture.png

# Instance-specific planning docs
planning/STATE.md
planning/MIGRATION.md
planning/agent-zero-fork/
planning/API-KEYS.md

# Personal debug tools
scripts/spot-fix-embed.py
scripts/reembed.sh

# Installed god packages — managed by God SDK
.pantheon/

# God exports — portable tarballs generated by pantheon-bundle
god-exports/

# OS artifacts
.DS_Store
Thumbs.db

# Personal user context — relationships, real names, private info
user.md
reports/*.json

# Beelink provisioning secrets (the .example is committed, the .env is not)
scripts/beelink-web.env

# =============================================================================
# Added 2026-06-12 — bulk-push cleanup before GitHub upload
# =============================================================================

# n8n runtime: cache dir (rendered JS/CSS assets, ~300MB) and .n8n state
n8n-data/.cache/
n8n-data/.8n/
n8n-data/database.sqlite
n8n-data/n8nEventLog*.log

# WebUI build outputs (Vite emits content-hashed JS/CSS, not source)
webui/static/assets/

# Local backup files (e.g. `something.py.bak.pre-xxx-20260608-173641`)
# These are local-only safety nets; never push.
*.bak

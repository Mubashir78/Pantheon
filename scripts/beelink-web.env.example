# beelink-web.env — Required env vars for beelink-web.sh
#
# Copy this file to beelink-web.env and fill in the real values
# before running the provisioning script. Keep it OUT of version
# control — it contains secrets.

# ─────────────────────────────────────────────────────────────────────
# Domain (Cloudflare DNS)
# ─────────────────────────────────────────────────────────────────────
THEOFORGE_DOMAIN=theoforgesolutions.com

# ─────────────────────────────────────────────────────────────────────
# Cloudflare Tunnel
# Get from: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Click your tunnel → "Configure" → copy the token from the "Install connector"
# step. It looks like: eyJhIjoixxxxxxxxx...
# ─────────────────────────────────────────────────────────────────────
CF_TUNNEL_TOKEN=***
CF_ACCOUNT_ID=***
CF_ZONE_ID=***

# ─────────────────────────────────────────────────────────────────────
# Tailscale
# Get from: https://login.tailscale.com/admin/settings/keys
# Generate a reusable, pre-approved auth key. Tag it "tag:beelink" if
# you've set up ACL tags; otherwise the default works.
# ─────────────────────────────────────────────────────────────────────
TAILSCALE_AUTHKEY=tskey-***

# ─────────────────────────────────────────────────────────────────────
# Resend (transactional email for the contact form)
# Sign up at https://resend.com (free tier: 3,000 emails/month)
# Get API key at https://resend.com/api-keys
# The FROM address must be on a domain you've verified in Resend
# (theoforgesolutions.com is the natural choice)
# ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_***
RESEND_FROM_EMAIL=noreply@theoforgesolutions.com
CONTACT_TO_EMAIL=konan@theoforgesolutions.com

# ─────────────────────────────────────────────────────────────────────
# CyberPanel admin
# Used during the CyberPanel install. Save these credentials in your
# password manager — they're the only way into the admin UI.
# ─────────────────────────────────────────────────────────────────────
CYBERPANEL_ADMIN_EMAIL=admin@theoforgesolutions.com
CYBERPANEL_ADMIN_USER=admin
CYBERPANEL_ADMIN_PASSWORD=***
CYBERPANEL_MYSQL_PASSWORD=***

# ─────────────────────────────────────────────────────────────────────
# Tallon (Enterprise Pantheon user)
# Username on the Beelink for Tallon's CyberPanel + file access
# His Tailscale identity is separate — invite him from
# https://login.tailscale.com/admin/invite
# ─────────────────────────────────────────────────────────────────────
TALLON_USERNAME=tallon

# ─────────────────────────────────────────────────────────────────────
# Olympus UI static build
# Either a directory containing index.html, assets/, icons/, etc.
# (typically a copy of ~/pantheon/webui/static/) OR a tarball of the same.
# After running deploy-olympus.sh on the main PC, you can:
#   scp -r ~/pantheon/webui/static konan@<beelink>:/tmp/olympus-static/
#   OLYMPUS_STATIC_SOURCE=/tmp/olympus-static/
# ─────────────────────────────────────────────────────────────────────
OLYMPUS_STATIC_SOURCE=/root/olympus-ui-static/

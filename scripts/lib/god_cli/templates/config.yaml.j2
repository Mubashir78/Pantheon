model:
  base_url: ''
  default: $MODEL
  provider: $PROVIDER
providers:
  $PROVIDER:
    models:
    - $MODEL
fallback_providers: []
credential_pool_strategies: {}
toolsets:
- hermes-cli
agent:
  max_turns: 90
  gateway_timeout: 1800
  restart_drain_timeout: 60
  api_max_retries: 3
  service_tier: ''
  tool_use_enforcement: auto
  image_input_mode: auto
terminal:
  backend: local
  modal_mode: auto
  cwd: /home/$USER/pantheon
  timeout: 180
  env_passthrough: []
  shell_init_files: []
  auto_source_bashrc: true
checkpoints:
  enabled: true
  max_snapshots: 50
  retention_days: 7
skills:
  external_dirs: []
  template_vars: true
mcp_servers:
  pantheon:
    url: "http://127.0.0.1:8010/mcp"
    timeout: 60
  pantheon-web-tools:
    transport: stdio
    command: /home/$USER/.hermes/hermes-agent/venv/bin/python3
    args:
    - /home/$USER/.hermes/scripts/pantheon-web-tools.py
    timeout: 60
  github:
    transport: stdio
    command: npx
    args:
    - '@modelcontextprotocol/server-github'
    enabled: true
    env:
      GITHUB_TOKEN: "ghp_placeholder"
  composio:
    url: https://connect.composio.dev/mcp
    timeout: 180
    headers:
      Authorization: "Bearer your_composio_oauth_token"
      x-consumer-api-key: "ck_4_a3xj4nUm0DCd-hJUnk"
  playwright:
    transport: stdio
    command: npx
    args:
    - '@playwright/mcp@latest'
    - --cdp-endpoint
    - http://localhost:9222
    enabled: true
